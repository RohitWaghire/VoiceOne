{
  "manifest_version": 3,
  "name": "VoiceOne",
  "version": "1.0.0",
  "description": "Translate selected text and read it aloud using Chrome's built-in on-device AI (Translator + chrome.tts). Works on web pages and PDFs.",
  "minimum_chrome_version": "138",
  "permissions": [
    "tts",
    "contextMenus",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VoiceOne"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
